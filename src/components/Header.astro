---
import PERSONAL_DATA from "@data/personal";
import Search from "@components/Search.astro";
import { getCollection } from "astro:content";

const isDev = import.meta.env.DEV;
const allPosts = await getCollection("blogPosts");
const posts = allPosts
  .filter(p => p.data.isPublic || isDev)
  .map(p => ({
    id: p.id,
    title: p.data.title,
    subTitle: p.data.subTitle ?? null,
    tags: p.data.tags,
    publishedDate: p.data.publishedDate.toISOString(),
  }));
---

<div class="title-container">
  <a href="/"><h1>{PERSONAL_DATA.firstName}'s Blog</h1></a>

  <div class="header-right">
    <Search posts={posts} />

    <div class="social-links">
      <a href={PERSONAL_DATA.website}>
        <i class="bi bi-globe" />
      </a>
      <a href=`mailto:${PERSONAL_DATA.email}`>
        <i class="bi bi-envelope-at" />
      </a>
      {PERSONAL_DATA.socialMedia.map(i => (
        <a href={i.url}>
          <i class=`bi ${i.icon}` />
        </a>
      ))}
    </div>
  </div>
</div>

<style>
a {
  color: var(--text);
  text-decoration: none;
  transition: color 120ms;
}

a:hover {
  color: var(--text-muted);
}

.title-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.social-links {
  display: flex;
  align-items: center;
  gap: 0.1rem;
}

.social-links a {
  margin-left: 0.4rem;
  font-size: 1.5rem;
}

@media (max-width: 600px) {
  .title-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .header-right {
    justify-content: flex-end;
  }
}
</style>
